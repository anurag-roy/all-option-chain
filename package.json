{
  "workspaces": [
    "client"
  ],
  "type": "module",
  "name": "all-option-chain",
  "version": "1.0.0",
  "description": "NSE Option Chain using Kite APIs",
  "main": "server/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env server/index.ts",
    "dev:client": "npm --prefix client run dev",
    "build": "npx tsx server/scripts/build.ts",
    "start": "tsx --env-file=.env server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"{server,client/src}/**/*.{js,jsx,ts,tsx,css,json,md}\"",
    "db": "drizzle-kit",
    "db:seed": "tsx --env-file=.env server/scripts/seed.ts",
    "data:prepare": "npm run db:migrate && npm run db:seed",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "login": "tsx --env-file=.env server/scripts/login.ts",
    "auto-login": "tsx --env-file=.env server/scripts/auto-login.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anurag-roy/all-option-chain.git"
  },
  "keywords": [
    "NSE",
    "Option",
    "Chain",
    "Zerodha",
    "Kite"
  ],
  "author": "Anurag Roy <anuragroy@duck.com> (https://anuragroy.dev)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/anurag-roy/all-option-chain/issues"
  },
  "homepage": "https://github.com/anurag-roy/all-option-chain#readme",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@date-fns/tz": "^1.5.0",
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.3.1",
    "@hono/zod-validator": "^0.8.0",
    "@hookform/resolvers": "^5.4.0",
    "@libsql/client": "^0.17.4",
    "@tailwindcss/vite": "^4.3.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "es-toolkit": "^1.47.1",
    "hono": "^4.12.26",
    "json-2-csv": "^5.5.11",
    "kiteconnect-ts": "^2.0.0",
    "otplib": "^13.4.1",
    "p-queue": "^9.3.0",
    "picocolors": "^1.1.1",
    "react-hook-form": "^7.80.0",
    "tailwindcss": "^4.3.1",
    "tough-cookie": "^6.0.1",
    "zod": "^4.4.3"
  }
}
